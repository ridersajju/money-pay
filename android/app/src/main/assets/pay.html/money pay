            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            max-width: 800px;
            width: 100%;
        }

        header {
            text-align: center;
            color: #00ffd5;
            margin-bottom: 40px;
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 0 0 20px rgba(0, 255, 213, 0.5);
        }

        header p {
            color: #cbd5e1;
            font-size: 1rem;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            background: #111827;
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 0 40px rgba(0, 255, 213, 0.1);
            border: 1px solid rgba(0, 255, 213, 0.2);
        }

        .card h2 {
            color: #00ffd5;
            margin-bottom: 20px;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .balance-card {
            grid-column: 1 / -1;
            background: linear-gradient(135deg, rgba(0, 255, 213, 0.1), rgba(0, 255, 213, 0.05));
            border: 2px solid rgba(0, 255, 213, 0.3);
        }

        .balance-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .balance-item {
            text-align: center;
        }

        .balance-label {
            color: #94a3b8;
            font-size: 0.9rem;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .balance-amount {
            color: #00ffd5;
            font-size: 2.5rem;
            font-weight: bold;
            text-shadow: 0 0 20px rgba(0, 255, 213, 0.3);
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            color: #cbd5e1;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        input[type="text"],
        input[type="email"],
        input[type="number"],
        select {
            width: 100%;
            padding: 12px 15px;
            background: #0f172a;
            border: 1px solid rgba(0, 255, 213, 0.2);
            border-radius: 10px;
            color: #e2e8f0;
            font-size: 1rem;
            transition: 0.3s;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="number"]:focus,
        select:focus {
            outline: none;
            border-color: #00ffd5;
            box-shadow: 0 0 15px rgba(0, 255, 213, 0.2);
            background: rgba(0, 255, 213, 0.05);
        }

        select option {
            background: #0f172a;
            color: #e2e8f0;
        }

        .payment-methods {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }

        .method-option {
            position: relative;
        }

        .method-option input[type="radio"] {
            display: none;
        }

        .method-label {
            display: block;
            padding: 15px;
            background: #0f172a;
            border: 1px solid rgba(0, 255, 213, 0.2);
            border-radius: 10px;
            cursor: pointer;
            text-align: center;
            color: #cbd5e1;
            transition: 0.3s;
            font-size: 0.9rem;
        }

        .method-option input[type="radio"]:checked + .method-label {
            background: rgba(0, 255, 213, 0.2);
            border-color: #00ffd5;
            color: #00ffd5;
        }

        .amount-input-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .submit-btn {
            width: 100%;
            padding: 14px;
            background: #00ffd5;
            color: #000;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .submit-btn:hover {
            background: #00d99f;
            transform: scale(1.02);
            box-shadow: 0 0 20px rgba(0, 255, 213, 0.4);
        }

        .recent-transactions {
            grid-column: 1 / -1;
        }

        .transaction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: rgba(0, 255, 213, 0.05);
            border: 1px solid rgba(0, 255, 213, 0.1);
            border-radius: 10px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

        .transaction-item:hover {
            border-color: rgba(0, 255, 213, 0.3);
            background: rgba(0, 255, 213, 0.1);
        }

        .transaction-details {
            flex: 1;
        }

        .transaction-name {
            color: #e2e8f0;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .transaction-time {
            color: #94a3b8;
            font-size: 0.85rem;
        }

        .transaction-amount {
            font-size: 1.2rem;
            font-weight: bold;
            text-align: right;
        }

        .transaction-amount.sent {
            color: #ef4444;
        }

        .transaction-amount.received {
            color: #22c55e;
        }

        .transaction-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-right: 15px;
            font-size: 1.5rem;
            background: rgba(0, 255, 213, 0.1);
        }

        .transaction-info {
            display: flex;
            align-items: center;
            flex: 1;
        }

        .security-info {
            background: rgba(34, 197, 94, 0.1);
            border-left: 4px solid #22c55e;
            border-radius: 5px;
            padding: 12px 15px;
            color: #86efac;
            font-size: 0.9rem;
            margin-top: 20px;
            grid-column: 1 / -1;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }

            .balance-info {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            header h1 {
                font-size: 1.8rem;
            }

            .amount-input-group {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

